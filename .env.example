# ============================================================
# Desa Digital v3 
# ============================================================
# Salin file ini menjadi .env.local dan isi nilai sebenarnya.
# Firebase Client SDK 
NEXT_PUBLIC_FIREBASE_APIKEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGE_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:3000/

# MongoDB Utama
MONGODB_URL=mongodb://mongodb:27017/
MONGODB_DB_NAME=desa_digital_db

# MongoDB Testing (Performa)
MONGODB_TEST_URL=mongodb://mongodb_test:27017/
MONGODB_TEST_DB_NAME=desa_digital_test_db

# Redis
REDIS_URL=redis://redis:6379

# Ollama (Embedding Server)
# Lokal (Docker):        http://localhost:11434
# Via ngrok (publik):    https://xxxx-xxxx.ngrok-free.app  (lihat http://localhost:4040)
# Next.js dalam Docker:  http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=your_embed_model

# Ngrok (opsional — hanya diperlukan saat Ollama perlu diakses dari publik)
# Daftar dan ambil authtoken di: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Google Generative AI (Chatbot LLM)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Guard LLM (model ringan untuk validasi query sebelum masuk ke RAG)
GUARD_LLM_PROVIDER=auto
GUARD_LLM_MODEL=
GUARD_LLM_TIMEOUT_MS=3000

# Auth
JWT_SECRET=generate_a_random_secret_key_here
FRONTEND_URL=http://localhost:3000

# Resend Email 
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=Desa Digital <onboarding@resend.dev>

# Firebase Admin SDK (server-side)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# API Access
ALLOWED_IPS=127.0.0.1,::1
INTERNAL_API_KEY=--@desa-digital-2026@--

# API Rekomendasi Eksternal (FastAPI)
# Jika di lokal/Docker, gunakan nama container (misal: http://recommendation:8000/api/v1)
# Jika masih di Vercel, gunakan: https://ddi-recommendation.vercel.app/api/v1
RECOMMENDATION_API_URL=http://recommendation:8000/api/v1
