# ============================================================
# Desa Digital v3 
# ============================================================
# Salin file ini menjadi .env.local dan isi nilai sebenarnya.
# Firebase Client SDK 
NEXT_PUBLIC_FIREBASE_APIKEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGE_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:3000/

# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGODB_DB_NAME=desa_digital_db

# Ollama (Embedding Server)
# Lokal (Docker):        http://localhost:11434
# Via ngrok (publik):    https://xxxx-xxxx.ngrok-free.app  (lihat http://localhost:4040)
# Next.js dalam Docker:  http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=your_embed_model

# Ngrok (opsional — hanya diperlukan saat Ollama perlu diakses dari publik)
# Daftar dan ambil authtoken di: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Google Generative AI (Chatbot LLM)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Guard LLM (model ringan untuk validasi query sebelum masuk ke RAG)
GUARD_LLM_PROVIDER=auto
GUARD_LLM_MODEL=
GUARD_LLM_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# RAG & Prompt Limits — semua opsional, nilai default sudah aman untuk produksi
# ---------------------------------------------------------------------------

# Batas panjang content (chars) saat hasil retrieval diproses di rag-utils
CONTEXT_MAX_CHARS=800

# Batas jumlah dokumen dari doc_embeddings yang masuk ke prompt
DOC_RESULT_LIMIT=3

# Batas jumlah dokumen dari db_embeddings yang masuk ke prompt
DB_RESULT_LIMIT=3

# Batas panjang jawaban dari LLM (dalam token)
LLM_MAX_OUTPUT_TOKENS=400

# Batas panjang tiap context item saat prompt final dibuat (chars)
PROMPT_CONTEXT_MAX_CHARS=500

# Jumlah pesan history yang dimasukkan ke prompt
HISTORY_MESSAGE_LIMIT=6

# Batas panjang tiap pesan history (chars)
HISTORY_MESSAGE_MAX_CHARS=300

# Jumlah kandidat vector search (internal)
VECTOR_NUM_CANDIDATES=50

# Jumlah hasil mentah dari vector search sebelum difilter threshold
VECTOR_SEARCH_LIMIT=5

# Threshold skor minimum vector search (0.0 - 1.0)
VECTOR_SCORE_THRESHOLD=0.6

# Auth
JWT_SECRET=generate_a_random_secret_key_here
FRONTEND_URL=http://localhost:3000

# Resend Email 
# RESEND_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=Desa Digital <onboarding@resend.dev>

# Firebase Admin SDK (server-side)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
