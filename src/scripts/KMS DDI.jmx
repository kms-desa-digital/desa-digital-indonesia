  },&#xd;
  &quot;logo&quot;: &quot;${logoDesa}&quot;,&#xd;
  &quot;header&quot;: &quot;${headerDesa}&quot;,&#xd;
  &quot;images&quot;: [&quot;${fotoInovasi}&quot;],&#xd;
