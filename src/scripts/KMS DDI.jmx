  &quot;namaDesa&quot;: &quot;${namaDesa}&quot;,&#xd;
  &quot;inovasiId&quot;: &quot;${inovasiId}&quot;, // Kosongkan jika Klaim Manual&#xd;
  &quot;namaInovasi&quot;: &quot;${namaInovasi}&quot;,&#xd;
  &quot;namaInovator&quot;: &quot;${namaInovator}&quot;,&#xd;
  &quot;deskripsiInovasi&quot;: &quot;${desInovasi}&quot;,&#xd;
  &quot;buktiJenis&quot;: [&quot;${dokumen}&quot;, &quot;${foto}&quot;, &quot;${video}&quot;], // Pilih: foto, video, atau dokumen&#xd;
  &quot;buktiFiles&quot;: {&#xd;
    &quot;dokumen&quot;: [&quot;${buktiDokumen}&quot;],&#xd;
    &quot;foto&quot;: [&quot;${buktiFoto}&quot;],&#xd;
    &quot;video&quot;: [&quot;${buktiVideo}&quot;]&#xd;
  },&#xd;
  &quot;isManual&quot;: ${status} // Set true jika inovasi yang diklaim tidak ada di daftar aplikasi&#xd;
